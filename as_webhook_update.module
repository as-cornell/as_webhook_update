<?php

/**
 * @file
 * Webhook update module for sending entity changes to remote systems.
 *
 * This module uses an OOP architecture with services, extractors, and
 * dependency injection to send webhook notifications when entities are
 * created, updated, or deleted.
 */

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_ENTITY_TYPE_postinsert() for nodes.
 */
function as_webhook_update_node_postinsert(EntityInterface $entity) {
  \Drupal::service('as_webhook_update.dispatcher')->dispatch($entity, 'create');
}

/**
 * Implements hook_ENTITY_TYPE_postupdate() for nodes.
 */
function as_webhook_update_node_postupdate(EntityInterface $entity) {
  \Drupal::service('as_webhook_update.dispatcher')->dispatch($entity, 'update');
}


/**
 * Implements hook_ENTITY_TYPE_postinsert() for taxonomy terms.
 */
function as_webhook_update_taxonomy_term_postinsert(EntityInterface $entity) {
  \Drupal::service('as_webhook_update.dispatcher')->dispatch($entity, 'create');
}


/**
 * Implements hook_ENTITY_TYPE_postupdate() for taxonomy terms.
 */
function as_webhook_update_taxonomy_term_postupdate(EntityInterface $entity) {
  \Drupal::service('as_webhook_update.dispatcher')->dispatch($entity, 'update');
}

/**
 * Implements hook_ENTITY_TYPE_postdelete() for nodes.
 */
function as_webhook_update_node_postdelete(EntityInterface $entity) {
  \Drupal::service('as_webhook_update.dispatcher')->dispatch($entity, 'delete');
}
